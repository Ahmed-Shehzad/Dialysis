<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Dialysis.Lab.Tests</RootNamespace>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <Description>Tests for the Lab bounded context — order aggregate, command validators, and the GDPR eraser/extractor against a PostgreSQL Testcontainer.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Shouldly" />
    <PackageReference Include="Testcontainers.PostgreSql" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../Dialysis.Lab.Api/Dialysis.Lab.Api.csproj" />
    <ProjectReference Include="../Dialysis.Lab.Contracts/Dialysis.Lab.Contracts.csproj" />
    <ProjectReference Include="../Dialysis.Lab.Orders/Dialysis.Lab.Orders.csproj" />
    <ProjectReference Include="../Dialysis.Lab.Persistence/Dialysis.Lab.Persistence.csproj" />
    <ProjectReference Include="../../Shared/Dialysis.Module.Hosting.Testing/Dialysis.Module.Hosting.Testing.csproj" />
  </ItemGroup>

</Project>
