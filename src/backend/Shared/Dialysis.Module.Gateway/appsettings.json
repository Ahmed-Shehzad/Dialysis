{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Gateway": {
    "Authority": "",
    "Audience": "account",
    "RequireAuthentication": false,
    "Cors": {
      "AllowedOrigins": []
    }
  },
  "ReverseProxy": {
    "Routes": {
      "identity": {
        "ClusterId": "identity",
        "Match": { "Path": "/identity/{**catch-all}" },
        "AuthorizationPolicy": "anonymous",
        "Transforms": [
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "auth": {
        "ClusterId": "keycloak",
        "Match": { "Path": "/auth/{**catch-all}" },
        "AuthorizationPolicy": "anonymous",
        "Transforms": [
          { "PathRemovePrefix": "/auth" },
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "his-api": {
        "ClusterId": "his",
        "Match": { "Path": "/api/his/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "Transforms": [
          { "PathRemovePrefix": "/api/his" }
        ]
      },
      "ehr-api": {
        "ClusterId": "ehr",
        "Match": { "Path": "/api/ehr/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "Transforms": [
          { "PathRemovePrefix": "/api/ehr" }
        ]
      },
      "pdms-api": {
        "ClusterId": "pdms",
        "Match": { "Path": "/api/pdms/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "Transforms": [
          { "PathRemovePrefix": "/api/pdms" }
        ]
      },
      "smartconnect-api": {
        "ClusterId": "smartconnect",
        "Match": { "Path": "/api/smartconnect/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "Transforms": [
          { "PathRemovePrefix": "/api/smartconnect" }
        ]
      },
      "hie-api": {
        "ClusterId": "hie",
        "Match": { "Path": "/api/hie/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "Transforms": [
          { "PathRemovePrefix": "/api/hie" }
        ]
      },
      "fhir-his": {
        "ClusterId": "his",
        "Match": { "Path": "/fhir/his/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "Transforms": [
          { "PathPattern": "fhir/{**catch-all}" }
        ]
      },
      "fhir-pdms": {
        "ClusterId": "pdms",
        "Match": { "Path": "/fhir/pdms/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "Transforms": [
          { "PathPattern": "fhir/{**catch-all}" }
        ]
      },
      "fhir-ehr": {
        "ClusterId": "ehr",
        "Match": { "Path": "/fhir/ehr/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "Transforms": [
          { "PathPattern": "fhir/{**catch-all}" }
        ]
      },
      "hub-pdms": {
        "ClusterId": "pdms",
        "Match": { "Path": "/hubs/vitals/{**catch-all}" },
        "AuthorizationPolicy": "authenticated",
        "Transforms": [
          { "PathPattern": "hubs/vitals/{**catch-all}" }
        ]
      },
      "web-spa": {
        "ClusterId": "web",
        "Match": { "Path": "/{**catch-all}" },
        "Order": 1000,
        "AuthorizationPolicy": "anonymous"
      }
    },
    "Clusters": {
      "identity": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:15",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health/live"
          },
          "Passive": { "Enabled": true, "Policy": "TransportFailureRate" }
        },
        "Destinations": {
          "d1": { "Address": "http://localhost:5275/" }
        }
      },
      "keycloak": {
        "Destinations": {
          "d1": { "Address": "http://localhost:8081/" }
        }
      },
      "web": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5173/" }
        }
      },
      "his": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:15",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health/live"
          },
          "Passive": { "Enabled": true, "Policy": "TransportFailureRate" }
        },
        "Destinations": {
          "d1": { "Address": "http://localhost:5288/" }
        }
      },
      "ehr": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": { "Enabled": true, "Interval": "00:00:15", "Timeout": "00:00:05", "Policy": "ConsecutiveFailures", "Path": "/health/live" },
          "Passive": { "Enabled": true, "Policy": "TransportFailureRate" }
        },
        "Destinations": { "d1": { "Address": "http://localhost:5111/" } }
      },
      "pdms": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": { "Enabled": true, "Interval": "00:00:15", "Timeout": "00:00:05", "Policy": "ConsecutiveFailures", "Path": "/health/live" },
          "Passive": { "Enabled": true, "Policy": "TransportFailureRate" }
        },
        "Destinations": { "d1": { "Address": "http://localhost:5112/" } }
      },
      "smartconnect": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": { "Enabled": true, "Interval": "00:00:15", "Timeout": "00:00:05", "Policy": "ConsecutiveFailures", "Path": "/health/live" },
          "Passive": { "Enabled": true, "Policy": "TransportFailureRate" }
        },
        "Destinations": { "d1": { "Address": "http://localhost:5113/" } }
      },
      "hie": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": { "Enabled": true, "Interval": "00:00:15", "Timeout": "00:00:05", "Policy": "ConsecutiveFailures", "Path": "/health/live" },
          "Passive": { "Enabled": true, "Policy": "TransportFailureRate" }
        },
        "Destinations": { "d1": { "Address": "http://localhost:5095/" } }
      }
    }
  }
}
