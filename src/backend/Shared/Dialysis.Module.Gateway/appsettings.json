      "identity": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/identity/{**catch-all}"
        },
        "AuthorizationPolicy": "anonymous",
        "Transforms": [
          {
            "RequestHeaderOriginalHost": "true"
          }
        ]
      },
      "auth": {
        "ClusterId": "keycloak",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "AuthorizationPolicy": "anonymous",
        "Transforms": [
          {
            "PathRemovePrefix": "/auth"
          },
          {
            "RequestHeaderOriginalHost": "true"
          }
        ]
      },
      "his-bff-identity": {
        "ClusterId": "his-bff",
        "Match": {
