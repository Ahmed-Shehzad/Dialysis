{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Gateway": {
    "Authority": "",
    "Audience": "account",
    "RequireAuthentication": false,
    "Cors": {
      "AllowedOrigins": []
    }
