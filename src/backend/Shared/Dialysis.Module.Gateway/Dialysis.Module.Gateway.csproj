<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Dialysis.Module.Gateway</RootNamespace>
    <Description>YARP reverse-proxy host: routes /identity/*, /his/*, /smartconnect/*, /ehr/*, /pdms/*, /portal/* to the per-module API hosts and forwards bearer tokens.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Yarp.ReverseProxy" />
  </ItemGroup>

</Project>
