<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Dialysis.Module.Hosting</RootNamespace>
    <AssemblyName>Dialysis.Module.Hosting</AssemblyName>
    <Description>Shared composition root for modular monolith hosts: JWT auth, current user, authorization pipeline, audit, OTel, problem details, OpenAPI, health, correlation id, resilient HTTP defaults.</Description>
