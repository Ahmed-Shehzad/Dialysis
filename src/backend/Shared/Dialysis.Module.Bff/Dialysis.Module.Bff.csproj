<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Dialysis.Module.Bff</RootNamespace>
    <Description>Reusable Backend-for-Frontend building block: per-context OIDC + cookie session, /{context}/identity endpoints, and a YARP proxy that forwards the session's bearer to the owning module API. Mirrors Dialysis.Module.Hosting / Dialysis.Module.Gateway.</Description>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Authentication.OpenIdConnect" />
    <PackageReference Include="Yarp.ReverseProxy" />
  </ItemGroup>

  <ItemGroup>
    <!-- Valkey-backed IDistributedCache + Data Protection key ring for the server-side cookie
         ticket store (keeps the per-context BFF cookie down to a session key on the shared origin). -->
    <ProjectReference Include="../../BuildingBlocks/DistributedCache/Dialysis.BuildingBlocks.DistributedCache.Valkey/Dialysis.BuildingBlocks.DistributedCache.Valkey.csproj" />
    <ProjectReference Include="../../BuildingBlocks/Transponder/Scheduling/Transponder.Scheduling.Hangfire/Transponder.Scheduling.Hangfire.csproj" />
  </ItemGroup>

</Project>
