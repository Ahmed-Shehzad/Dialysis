<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Dialysis.Hie.Api</RootNamespace>
    <Description>ASP.NET host for the Dialysis Health Information Exchange module — bidirectional FHIR R4 + openEHR longitudinal store.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Asp.Versioning.Mvc" />
    <PackageReference Include="Asp.Versioning.Mvc.ApiExplorer" />
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../Dialysis.Hie.Composition/Dialysis.Hie.Composition.csproj" />
    <ProjectReference Include="../Dialysis.Hie.Contracts/Dialysis.Hie.Contracts.csproj" />
    <ProjectReference Include="../Dialysis.Hie.Persistence/Dialysis.Hie.Persistence.csproj" />
    <ProjectReference Include="../Dialysis.Hie.Outbound/Dialysis.Hie.Outbound.csproj" />
    <ProjectReference Include="../Dialysis.Hie.Inbound/Dialysis.Hie.Inbound.csproj" />
    <ProjectReference Include="../Dialysis.Hie.Consent/Dialysis.Hie.Consent.csproj" />
    <ProjectReference Include="../Dialysis.Hie.OpenEhr/Dialysis.Hie.OpenEhr.csproj" />
    <ProjectReference Include="../../CQRS/Dialysis.CQRS.Core.Abstraction/Dialysis.CQRS.Core.Abstraction.csproj" />
    <ProjectReference Include="../../Shared/Dialysis.Module.Hosting/Dialysis.Module.Hosting.csproj" />
  </ItemGroup>

</Project>
