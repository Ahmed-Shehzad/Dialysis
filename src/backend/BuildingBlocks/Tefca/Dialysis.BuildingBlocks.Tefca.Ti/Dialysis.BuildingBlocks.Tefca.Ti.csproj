<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Dialysis.BuildingBlocks.Tefca.Ti</RootNamespace>
    <AssemblyName>Dialysis.BuildingBlocks.Tefca.Ti</AssemblyName>
    <Description>German Telematikinfrastruktur (TI) + elektronische Patientenakte (ePA) client scaffold for PDSG compliance. Includes SMC-B reader abstraction, multi-environment endpoint catalog (RU/TU/PU), and pluggable secrets providers (Azure Key Vault, AWS Secrets Manager, HashiCorp Vault).</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../../Fhir/Dialysis.BuildingBlocks.Fhir.Tefca/Dialysis.BuildingBlocks.Fhir.Tefca.csproj" />
    <ProjectReference Include="../../DataProtection/Dialysis.BuildingBlocks.DataProtection/Dialysis.BuildingBlocks.DataProtection.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Http" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Dialysis.BuildingBlocks.Tefca.Ti.Tests" />
  </ItemGroup>

</Project>
