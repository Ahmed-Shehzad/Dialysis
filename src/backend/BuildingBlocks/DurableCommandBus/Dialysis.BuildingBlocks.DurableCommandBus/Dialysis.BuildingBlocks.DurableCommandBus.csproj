<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Dialysis.BuildingBlocks.DurableCommandBus</RootNamespace>
    <AssemblyName>Dialysis.BuildingBlocks.DurableCommandBus</AssemblyName>
    <Description>Durable command bus: routes opted-in commands through the durable Transponder transport (publisher confirms, persistent messages, manual ack) so a temporary database outage no longer loses in-flight writes. Commands are applied by a per-module consumer that wraps the existing ICommandHandler in a single EF transaction with an idempotency ledger row, so a redelivery of the same CommandId is a no-op. Aggregates still persist current state via EF; the RMQ queue is a transient in-flight buffer, not an event log.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../../Transponder/Transponder.Abstractions/Transponder.Abstractions.csproj" />
    <ProjectReference Include="../../../CQRS/Dialysis.CQRS.Core.Abstraction/Dialysis.CQRS.Core.Abstraction.csproj" />
    <ProjectReference Include="../../../DomainDrivenDesign/Persistence/Dialysis.Domain.Driven.Design.Core.Persistence.Abstractions/Dialysis.Domain.Driven.Design.Core.Persistence.Abstractions.csproj" />
    <ProjectReference Include="../../Intercessor/Intercessor.Abstractions/Intercessor.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Dialysis.BuildingBlocks.DurableCommandBus.Tests" />
  </ItemGroup>

</Project>
