<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Dialysis.BuildingBlocks.Fhir</RootNamespace>
    <AssemblyName>Dialysis.BuildingBlocks.Fhir.Abstractions</AssemblyName>
    <Description>SDK-free abstractions for the cross-cutting FHIR R4 building block. Module *.Contracts assemblies may reference this without violating the contracts-purity rule — no Hl7.Fhir.* types live here.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>

</Project>
