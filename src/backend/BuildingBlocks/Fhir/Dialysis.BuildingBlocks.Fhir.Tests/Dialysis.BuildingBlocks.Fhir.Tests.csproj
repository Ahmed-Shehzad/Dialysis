<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Dialysis.BuildingBlocks.Fhir.Tests</RootNamespace>
    <AssemblyName>Dialysis.BuildingBlocks.Fhir.Tests</AssemblyName>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../Dialysis.BuildingBlocks.Fhir.Core/Dialysis.BuildingBlocks.Fhir.Core.csproj" />
    <ProjectReference Include="../Dialysis.BuildingBlocks.Fhir.CdaBridge/Dialysis.BuildingBlocks.Fhir.CdaBridge.csproj" />
    <ProjectReference Include="../Dialysis.BuildingBlocks.Fhir.AspNetCore/Dialysis.BuildingBlocks.Fhir.AspNetCore.csproj" />
    <ProjectReference Include="../Dialysis.BuildingBlocks.Fhir.BulkData/Dialysis.BuildingBlocks.Fhir.BulkData.csproj" />
    <ProjectReference Include="../Dialysis.BuildingBlocks.Fhir.DeIdentification/Dialysis.BuildingBlocks.Fhir.DeIdentification.csproj" />
    <ProjectReference Include="../Dialysis.BuildingBlocks.Fhir.Smart/Dialysis.BuildingBlocks.Fhir.Smart.csproj" />
    <ProjectReference Include="../Dialysis.BuildingBlocks.Fhir.Subscriptions/Dialysis.BuildingBlocks.Fhir.Subscriptions.csproj" />
    <ProjectReference Include="../Dialysis.BuildingBlocks.Fhir.Terminology/Dialysis.BuildingBlocks.Fhir.Terminology.csproj" />
    <ProjectReference Include="../Dialysis.BuildingBlocks.Fhir.Testing/Dialysis.BuildingBlocks.Fhir.Testing.csproj" />
    <ProjectReference Include="../Dialysis.BuildingBlocks.Fhir.Validation/Dialysis.BuildingBlocks.Fhir.Validation.csproj" />
    <PackageReference Include="Hl7.Fhir.R4" />
    <!-- Brings specification.zip (FHIR R4 core conformance) into the test output so the snapshot
         generator / ZipSource.CreateValidationSource() can resolve base definitions. -->
    <PackageReference Include="Hl7.Fhir.Specification.R4" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="Shouldly" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
  </ItemGroup>

</Project>
