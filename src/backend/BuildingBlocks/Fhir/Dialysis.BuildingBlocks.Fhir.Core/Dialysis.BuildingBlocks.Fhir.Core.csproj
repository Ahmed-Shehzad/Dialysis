<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Dialysis.BuildingBlocks.Fhir</RootNamespace>
    <AssemblyName>Dialysis.BuildingBlocks.Fhir.Core</AssemblyName>
    <Description>Cross-cutting FHIR R4 building block core: resource mapper contracts, OperationOutcome factory, JSON serializer provider, capability statement reflection, registration entry point (AddFhir).</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../Dialysis.BuildingBlocks.Fhir.Abstractions/Dialysis.BuildingBlocks.Fhir.Abstractions.csproj" />
    <PackageReference Include="Hl7.Fhir.R4" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>

</Project>
