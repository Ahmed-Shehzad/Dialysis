<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Dialysis.BuildingBlocks.DistributedCache.Valkey</RootNamespace>
    <AssemblyName>Dialysis.BuildingBlocks.DistributedCache.Valkey</AssemblyName>
    <Description>Valkey (Redis-compatible) distributed cache + data-protection key ring + health check for horizontally-scaled module hosts.</Description>
  </PropertyGroup>

  <!--
    Valkey GLIDE is the only data-plane client. The IDistributedCache, ASP.NET Data Protection
    key-ring, and health-check integrations that used to come from the StackExchange.Redis
    ecosystem packages are now hand-rolled GLIDE adapters in this project, so we depend on the
    ASP.NET shared framework (IDistributedCache / DataProtection / HealthChecks abstractions,
    Configuration binder, Options) plus the GLIDE client itself.
  -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Valkey.Glide" />
  </ItemGroup>

</Project>
