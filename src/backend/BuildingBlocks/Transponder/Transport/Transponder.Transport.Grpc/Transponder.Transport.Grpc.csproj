<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Dialysis.BuildingBlocks.Transponder.Transport.Grpc</RootNamespace>
    <AssemblyName>Transponder.Transport.Grpc</AssemblyName>
    <Description>gRPC transport plugin for Transponder (client + ingress relay service).</Description>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../Transponder.Abstractions/Transponder.Abstractions.csproj" />
    <ProjectReference Include="../../Transponder.Core/Transponder.Core.csproj" />
    <PackageReference Include="Grpc.AspNetCore" />
    <PackageReference Include="Grpc.Net.Client" />
    <PackageReference Include="Grpc.Tools">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <Protobuf Include="Protos\transponder_ingress.proto" GrpcServices="Both" />
  </ItemGroup>

</Project>
