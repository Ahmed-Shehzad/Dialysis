<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Dialysis.SmartConnect.Persistence.ObjectStorage.S3</RootNamespace>
    <Description>S3-compatible attachment backend for SmartConnect (AWS S3, MinIO, Wasabi). Activate with services.AddSmartConnectS3AttachmentStore(...).</Description>

    <IsPackable>true</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../../Dialysis.SmartConnect.Core.Abstraction/Dialysis.SmartConnect.Core.Abstraction.csproj" />
    <ProjectReference Include="../../Dialysis.SmartConnect.Core/Dialysis.SmartConnect.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- AWSSDK.Core is pinned to a non-vulnerable version (>= 4.0.3.3 per GHSA-9cvc-h2w8-phrp).
         AWSSDK.S3 would otherwise resolve Core to 4.0.1.2 (the min in its dependency range) and
         NU1901 (vulnerability audit) breaks the build under TreatWarningsAsErrors. -->
    <PackageReference Include="AWSSDK.Core" />
    <PackageReference Include="AWSSDK.S3" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>

</Project>
