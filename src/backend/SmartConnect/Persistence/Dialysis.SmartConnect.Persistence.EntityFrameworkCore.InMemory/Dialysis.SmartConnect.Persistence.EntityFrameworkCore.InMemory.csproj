<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Dialysis.SmartConnect.Persistence.EntityFrameworkCore.InMemory</RootNamespace>
    <AssemblyName>Dialysis.SmartConnect.Persistence.EntityFrameworkCore.InMemory</AssemblyName>
    <Description>EF Core InMemory provider for SmartConnect persistence. Production use is discouraged — pair with EF.Postgresql for durable storage; this package targets tests and local smoke runs. Activate with services.AddSmartConnectPersistenceInMemory(...).</Description>

    <IsPackable>true</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../Dialysis.SmartConnect.Persistence.EntityFrameworkCore.Abstractions/Dialysis.SmartConnect.Persistence.EntityFrameworkCore.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>

</Project>
