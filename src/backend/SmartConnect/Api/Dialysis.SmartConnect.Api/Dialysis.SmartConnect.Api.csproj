<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Dialysis.SmartConnect.Api</RootNamespace>
    <AssemblyName>Dialysis.SmartConnect.Api</AssemblyName>
    <Description>ASP.NET host for the SmartConnect integration runtime (flows, inbound connectors, management API).</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../../Contracts/Dialysis.SmartConnect.Contracts/Dialysis.SmartConnect.Contracts.csproj" />
    <ProjectReference Include="../../Dialysis.SmartConnect.Core/Dialysis.SmartConnect.Core.csproj" />
    <!-- DICOMweb (WADO/QIDO/STOW-RS) read/store surface for imaging studies. The endpoints live in
         Dicom.Web; Dicom.Persistence supplies the EF instance store (on SmartConnectDbContext) +
         ingestion service. -->
    <ProjectReference Include="../../Dicom/Dialysis.SmartConnect.Dicom.Web/Dialysis.SmartConnect.Dicom.Web.csproj" />
    <ProjectReference Include="../../Dicom/Dialysis.SmartConnect.Dicom.Persistence/Dialysis.SmartConnect.Dicom.Persistence.csproj" />
    <!-- Lab integration: the host bridges inbound ORU results into the Lab context's typed event.
         Referencing Lab.Contracts from the host is permitted by the module-boundary arch test. -->
    <ProjectReference Include="../../../Lab/Dialysis.Lab.Contracts/Dialysis.Lab.Contracts.csproj" />
    <ProjectReference Include="../../Inbound/Dialysis.SmartConnect.Inbound.Abstractions/Dialysis.SmartConnect.Inbound.Abstractions.csproj" />
    <ProjectReference Include="../../Inbound/Dialysis.SmartConnect.Inbound.AspNetCore/Dialysis.SmartConnect.Inbound.AspNetCore.csproj" />
    <ProjectReference Include="../../Inbound/Dialysis.SmartConnect.Inbound.FileReader/Dialysis.SmartConnect.Inbound.FileReader.csproj" />
    <ProjectReference Include="../../Inbound/Dialysis.SmartConnect.Inbound.Mllp/Dialysis.SmartConnect.Inbound.Mllp.csproj" />
    <ProjectReference Include="../../Inbound/Dialysis.SmartConnect.Inbound.Sftp/Dialysis.SmartConnect.Inbound.Sftp.csproj" />
    <ProjectReference Include="../../Inbound/Dialysis.SmartConnect.Inbound.Transponder/Dialysis.SmartConnect.Inbound.Transponder.csproj" />
    <ProjectReference Include="../../Management/Dialysis.SmartConnect.Management.AspNetCore/Dialysis.SmartConnect.Management.AspNetCore.csproj" />
    <ProjectReference Include="../../Persistence/Dialysis.SmartConnect.Persistence.EntityFrameworkCore.InMemory/Dialysis.SmartConnect.Persistence.EntityFrameworkCore.InMemory.csproj" />
    <ProjectReference Include="../../../BuildingBlocks/Fhir/Dialysis.BuildingBlocks.Fhir.Audit/Dialysis.BuildingBlocks.Fhir.Audit.csproj" />
    <ProjectReference Include="../../../BuildingBlocks/Hipaa/Dialysis.BuildingBlocks.Hipaa/Dialysis.BuildingBlocks.Hipaa.csproj" />
    <ProjectReference Include="../../../BuildingBlocks/Hipaa/Dialysis.BuildingBlocks.Hipaa.AspNetCore/Dialysis.BuildingBlocks.Hipaa.AspNetCore.csproj" />
    <ProjectReference Include="../../../Shared/Dialysis.Module.Hosting/Dialysis.Module.Hosting.csproj" />
    <ProjectReference Include="../../../../aspire/Dialysis.ServiceDefaults/Dialysis.ServiceDefaults.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Operator-shell TS sources ride along in the project but never compile into the assembly. -->
    <None Include="operator-shell/**/*" Exclude="operator-shell/node_modules/**;operator-shell/.cache/**" />
  </ItemGroup>

  <Target Name="BuildOperatorShell" BeforeTargets="Build"
          Condition="Exists('$(MSBuildProjectDirectory)/operator-shell/node_modules')">
    <Exec WorkingDirectory="$(MSBuildProjectDirectory)/operator-shell"
          Command="npm run build" />
  </Target>

</Project>
