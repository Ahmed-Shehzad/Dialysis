<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Dialysis.SmartConnect.Api</RootNamespace>
    <AssemblyName>Dialysis.SmartConnect.Api</AssemblyName>
    <Description>ASP.NET host for the SmartConnect integration runtime (flows, inbound connectors, management API).</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../../Contracts/Dialysis.SmartConnect.Contracts/Dialysis.SmartConnect.Contracts.csproj" />
    <ProjectReference Include="../../Dialysis.SmartConnect.Core/Dialysis.SmartConnect.Core.csproj" />
    <ProjectReference Include="../../Inbound/Dialysis.SmartConnect.Inbound.Abstractions/Dialysis.SmartConnect.Inbound.Abstractions.csproj" />
    <ProjectReference Include="../../Inbound/Dialysis.SmartConnect.Inbound.AspNetCore/Dialysis.SmartConnect.Inbound.AspNetCore.csproj" />
    <ProjectReference Include="../../Inbound/Dialysis.SmartConnect.Inbound.Mllp/Dialysis.SmartConnect.Inbound.Mllp.csproj" />
    <ProjectReference Include="../../Management/Dialysis.SmartConnect.Management.AspNetCore/Dialysis.SmartConnect.Management.AspNetCore.csproj" />
    <ProjectReference Include="../../Persistence/Dialysis.SmartConnect.Persistence.EntityFrameworkCore.InMemory/Dialysis.SmartConnect.Persistence.EntityFrameworkCore.InMemory.csproj" />
    <ProjectReference Include="../../../Shared/Dialysis.Module.Hosting/Dialysis.Module.Hosting.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Operator-shell TS sources ride along in the project but never compile into the assembly. -->
    <None Include="operator-shell/**/*" Exclude="operator-shell/node_modules/**;operator-shell/.cache/**" />
  </ItemGroup>

  <Target Name="BuildOperatorShell" BeforeTargets="Build"
          Condition="Exists('$(MSBuildProjectDirectory)/operator-shell/node_modules')">
    <Exec WorkingDirectory="$(MSBuildProjectDirectory)/operator-shell"
          Command="npm run build" />
  </Target>

</Project>
