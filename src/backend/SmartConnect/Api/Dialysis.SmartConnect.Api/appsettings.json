{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SmartConnect": {
    "Authentication": {
      "Authority": "",
      "Audience": "smartconnect-api",
      "PermissionClaimType": "dialysis_permission",
      "RequireAuthorityWhenNotDevelopment": true
    },
    "DataPruner": {
      "IntervalHours": 1,
      "RetentionDays": 30
    },
    "Telemetry": {
      "OtlpEndpoint": ""
    }
  }
}
