{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Identity": "Host=localhost;Port=5444;Database=dialysis_identity;Username=postgres;Password=postgres"
  },
  "Identity": {
    "Authentication": {
      "Authority": "",
      "Audience": "identity-api",
      "PermissionClaimType": "dialysis_permission",
      "RequireAuthorityWhenNotDevelopment": true
    },
    "Transponder": {
      "EnableOutboxRelay": false,
      "RabbitMq": {
        "ConnectionUri": "",
        "QueueName": "dialysis.identity",
        "ExchangeName": "dialysis.identity.events"
      }
    },
    "Telemetry": {
      "OtlpEndpoint": ""
    }
  }
}
