{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Identity": {
    "Keycloak": {
      "Authority": "http://localhost:8080/realms/dialysis",
      "ClientId": "dialysis-bff",
      "ClientSecret": "bff-dev-secret-change-me",
      "HisAudienceClientId": "dialysis-his-api"
    },
    "Spa": {
      "DefaultReturnUrl": "/",
      "AllowedReturnUrlPrefixes": [
        "http://localhost:5173",
        "http://localhost:4173",
        "http://localhost:8080"
      ]
    }
  },
  "ReverseProxy": {
    "Routes": {
      "his_route": {
        "ClusterId": "his",
        "Match": {
          "Path": "/identity/his/{**remainder}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/identity/his"
          }
        ]
      }
    },
    "Clusters": {
      "his": {
        "Destinations": {
          "d1": {
            "Address": ""
          }
        }
      }
    }
  }
}
