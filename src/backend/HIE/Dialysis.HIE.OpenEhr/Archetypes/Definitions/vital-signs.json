    { "key": "systolic_mmhg",          "path": "Component[?].ValueQuantity.Value" },
    { "key": "diastolic_mmhg",         "path": "Component[?].ValueQuantity.Value" },
    { "key": "pulse_bpm",              "path": "Component[?].ValueQuantity.Value" },
    { "key": "respiration_per_min",    "path": "Component[?].ValueQuantity.Value" },
    { "key": "temperature_celsius",    "path": "Component[?].ValueQuantity.Value" },
    { "key": "spo2_percent",           "path": "Component[?].ValueQuantity.Value" },
    { "key": "method",                 "path": "Method.Coding[0].Code" },
