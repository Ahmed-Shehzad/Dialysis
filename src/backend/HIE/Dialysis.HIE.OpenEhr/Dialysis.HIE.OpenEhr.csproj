<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Dialysis.HIE.OpenEhr</RootNamespace>
    <Description>HIE openEHR slice: lightweight archetype-projected composition store.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../Dialysis.HIE.Core.Abstraction/Dialysis.HIE.Core.Abstraction.csproj" />
    <ProjectReference Include="../Dialysis.HIE.Core/Dialysis.HIE.Core.csproj" />
    <ProjectReference Include="../../BuildingBlocks/Transponder/Transponder.Abstractions/Transponder.Abstractions.csproj" />
    <ProjectReference Include="../../EHR/Dialysis.EHR.Contracts/Dialysis.EHR.Contracts.csproj" />
    <ProjectReference Include="../../PDMS/Dialysis.PDMS.Contracts/Dialysis.PDMS.Contracts.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Hl7.Fhir.R4" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>

  <ItemGroup>
    <!-- Archetype mapping catalog — shipped as embedded resources so the catalog loader
         can stream them at startup without any filesystem dependency on the host. Partner
         clinics can override / extend by registering additional definitions through
         AddArchetypeMappingDefinition(...) before the catalog auto-registers. -->
    <EmbeddedResource Include="Archetypes/Definitions/*.json" />
  </ItemGroup>

</Project>
