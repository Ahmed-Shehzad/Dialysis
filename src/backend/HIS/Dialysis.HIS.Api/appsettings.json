{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "His": {
    "Authentication": {
      "Authority": "",
      "Audience": "",
      "RequireAuthorityWhenNotDevelopment": false,
      "PermissionClaimType": "his_permission",
      "RoleClaimType": "http://schemas.microsoft.com/ws/2008/06/identity/claims/role",
      "PatientPortalPatientIdClaimType": "his_patient_id",
      "RolePermissionMap": {}
    },
    "PatientAccess": {
      "RequireExplicitConsentRowForPortal": false
    },
    "RequireHttpsRedirection": false,
    "UseHsts": false,
    "UseForwardedHeaders": false,
    "Laboratory": {
      "BaseUri": ""
    },
    "Pharmacy": {
      "BaseUri": ""
    },
    "Transponder": {
      "EnableOutboxRelay": false,
      "RabbitMq": {
        "ConnectionUri": "",
        "QueueName": "his.transponder",
        "ExchangeName": "transponder"
      }
    },
    "Telemetry": {
      "EnableOpenTelemetry": false,
      "OtlpExporterEndpoint": ""
    }
  }
}
