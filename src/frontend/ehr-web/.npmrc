# npm configuration for dialysis-web (React 18 + Vite + TypeScript).
# Keeps installs deterministic and quiet, and matches the flags the `predev`
# script, frontend-ci.yml, and the Dockerfile already pass on the command line.

# Always keep the committed package-lock.json authoritative so local installs,
# `npm ci` in the Dockerfile, and CI all resolve the same dependency graph.
package-lock=true

# Refuse to install under an unsupported toolchain (see "engines" in
# package.json) instead of failing later with cryptic build errors.
engine-strict=true

# Drop the audit/fund banners — not actionable in this workflow and already
# suppressed everywhere installs run.
fund=false
audit=false

# Pin the public registry explicitly so a stray user/global .npmrc can't
# redirect installs to a different feed.
registry=https://registry.npmjs.org/
