{
  "name": "dialysis-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "npm install --no-audit --no-fund --silent",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173 --host 0.0.0.0",
