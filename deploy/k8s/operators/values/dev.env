# Per-environment knobs sourced before rendering templates/*.yaml via envsubst.
# Dev: 1-replica everything — keeps the resource budget low for laptop clusters / kind.
DIALYSIS_ENV=dev
CNPG_INSTANCES=1
CNPG_MIN_SYNC_REPLICAS=0
CNPG_MAX_SYNC_REPLICAS=0
CNPG_STORAGE_SIZE=2Gi
CNPG_STORAGE_CLASS=standard
CNPG_BACKUP_BUCKET=s3://dialysis-wal-dev
CNPG_BACKUP_RETENTION=7d
RABBITMQ_REPLICAS=1
RABBITMQ_STORAGE_SIZE=2Gi
RABBITMQ_STORAGE_CLASS=standard
PGBOUNCER_REPLICAS=1
PGBOUNCER_POOL_SIZE=20
