# Prod: full HA — 3 Postgres replicas (primary + 1 sync + 1 async),
# 3-node quorum RMQ cluster. Storage classes are placeholders — swap to your
# cluster's regional SSD class before applying.
DIALYSIS_ENV=prod
CNPG_INSTANCES=3
CNPG_MIN_SYNC_REPLICAS=1
CNPG_MAX_SYNC_REPLICAS=1
CNPG_STORAGE_SIZE=100Gi
CNPG_STORAGE_CLASS=premium-rwo
CNPG_BACKUP_BUCKET=s3://dialysis-wal-prod
CNPG_BACKUP_RETENTION=30d
RABBITMQ_REPLICAS=3
RABBITMQ_STORAGE_SIZE=20Gi
RABBITMQ_STORAGE_CLASS=premium-rwo
PGBOUNCER_REPLICAS=3
PGBOUNCER_POOL_SIZE=100
# Region awareness — set per cluster install. The PRIMARY region renders only
# cloudnative-pg-clusters.yaml. The SECONDARY region(s) additionally render
# cnpg-multi-region-standby.yaml + skip the primary-only manifests.
# DIALYSIS_REGION_ROLE: primary | secondary
DIALYSIS_REGION_ROLE=primary
DIALYSIS_REGION=us-east-1
# Required when DIALYSIS_REGION_ROLE=secondary — points the standby cluster's
# externalClusters block at the primary region's WAL archive bucket.
DIALYSIS_PRIMARY_WAL_BUCKET=s3://dialysis-wal-prod
