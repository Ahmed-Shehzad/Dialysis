# Staging: 2 Postgres replicas (primary + 1 sync standby), single RMQ replica.
# Enough HA to exercise failover, not so much resource pressure that small clusters struggle.
DIALYSIS_ENV=staging
CNPG_INSTANCES=2
CNPG_MIN_SYNC_REPLICAS=1
CNPG_MAX_SYNC_REPLICAS=1
CNPG_STORAGE_SIZE=20Gi
CNPG_STORAGE_CLASS=standard-rwo
CNPG_BACKUP_BUCKET=s3://dialysis-wal-staging
CNPG_BACKUP_RETENTION=14d
RABBITMQ_REPLICAS=1
RABBITMQ_STORAGE_SIZE=10Gi
RABBITMQ_STORAGE_CLASS=standard-rwo
PGBOUNCER_REPLICAS=2
PGBOUNCER_POOL_SIZE=50
