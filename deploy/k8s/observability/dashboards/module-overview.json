{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "datasource", "uid": "grafana" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Per-module RED overview for every Dialysis host (module APIs, BFFs, gateway) plus the Transponder outbox relay. HTTP panels ride the OTel ASP.NET Core instrumentation every host wires via ModuleTelemetryExtensions (service.name → the Prometheus `job` label); outbox panels ride the Dialysis.Transponder.Outbox meter. Pair with the durable-command-bus dashboard and the Postgres/RabbitMQ operator dashboards.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Request rate (req/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_server_request_duration_seconds_count{job=~\"$service\"}[5m]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "description": "HTTP request throughput per host. A module dropping to zero while its BFF keeps receiving traffic means the BFF→API hop is broken (auth, service discovery, or the API is down)."
    },
    {
      "title": "5xx error ratio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_server_request_duration_seconds_count{job=~\"$service\", http_response_status_code=~\"5..\"}[5m])) / sum by (job) (rate(http_server_request_duration_seconds_count{job=~\"$service\"}[5m]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "description": "Share of requests answered 5xx. The ModuleHighServerErrorRatio alert pages at a sustained 5%."
    },
    {
      "title": "Latency p50 / p95 / p99 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (job, le) (rate(http_server_request_duration_seconds_bucket{job=~\"$service\"}[5m])))",
          "legendFormat": "{{job}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (job, le) (rate(http_server_request_duration_seconds_bucket{job=~\"$service\"}[5m])))",
          "legendFormat": "{{job}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (job, le) (rate(http_server_request_duration_seconds_bucket{job=~\"$service\"}[5m])))",
          "legendFormat": "{{job}} p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      },
      "description": "Server-side request latency quantiles. The ModuleHighP99Latency alert pages at a sustained p99 > 2s — chairside UIs sit on these APIs."
    },
    {
      "title": "In-flight requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (job) (http_server_active_requests{job=~\"$service\"})",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "description": "Concurrent requests per host. A climbing plateau with flat throughput = requests piling up behind a slow dependency (DB pool, partner endpoint)."
    },
    {
      "title": "Outbox publish rate (messages/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (context) (rate(dialysis_transponder_outbox_published_total[5m]))",
          "legendFormat": "{{context}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      },
      "description": "Integration events the relay published per module DbContext. Only hosts with EnableOutboxRelay emit; missing series = relay off by design (or the host is down)."
    },
    {
      "title": "Outbox publish failures (messages/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (context) (rate(dialysis_transponder_outbox_failed_total[5m]))",
          "legendFormat": "{{context}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      },
      "description": "Failed publish attempts. The relay halts the batch on first failure and retries the same (oldest) row next poll — sustained non-zero here plus growing age on the right = poison row."
    },
    {
      "title": "Outbox oldest pending age (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "max by (context) (dialysis_transponder_outbox_oldest_pending_age_seconds)",
          "legendFormat": "{{context}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "red", "value": 300 }
            ]
          }
        }
      },
      "description": "Age of the oldest unprocessed outbox row at the last relay poll. 0 = drained. Sustained growth = cross-module flows stalled for that module; TransponderOutboxRelayLagging pages at 5 minutes."
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["dialysis", "modules", "transponder"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus"
      },
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(http_server_request_duration_seconds_count, job)",
        "label": "Service",
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "",
  "title": "Dialysis — Module overview (RED + outbox)",
  "uid": "dialysis-module-overview",
  "version": 1
}
