{
  "resources": {
    "unit-registry": {
      "error": "This resource does not support generation in the manifest."
    },
    "k8s": {
      "error": "This resource does not support generation in the manifest."
    },
    "rabbitmq": {
      "type": "container.v1",
      "connectionString": "amqp://guest:{rabbitmq-password-uri-encoded.value}@{rabbitmq.bindings.tcp.host}:{rabbitmq.bindings.tcp.port}",
      "image": "docker.io/library/rabbitmq:4.3-management",
      "env": {
        "RABBITMQ_DEFAULT_USER": "guest",
        "RABBITMQ_DEFAULT_PASS": "{rabbitmq-password.value}"
      },
      "bindings": {
        "tcp": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "targetPort": 5672
        },
        "management": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 15672
        }
      }
    },
    "valkey": {
      "type": "container.v1",
      "connectionString": "{valkey.bindings.tcp.host}:{valkey.bindings.tcp.port},password={valkey-password.value}",
      "image": "docker.io/valkey/valkey:9.1",
      "entrypoint": "/bin/sh",
      "args": [
        "-c",
        "valkey-server --requirepass $VALKEY_PASSWORD"
      ],
      "env": {
        "VALKEY_PASSWORD": "{valkey-password.value}"
      },
      "bindings": {
        "tcp": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "targetPort": 6379
        }
      }
    },
    "keycloak-authority": {
      "type": "parameter.v0",
      "value": "{keycloak-authority.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "http://keycloak-service:8081/realms/dialysis"
          }
        }
      }
    },
    "gateway": {
      "type": "project.v1",
      "path": "../../../../../src/backend/Shared/Dialysis.Module.Gateway/Dialysis.Module.Gateway.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{gateway.bindings.http.targetPort}",
        "ASPNETCORE_URLS": "http://\u002B:9090",
        "Gateway__Authority": "{keycloak-authority.value}",
        "Gateway__Audience": "account",
        "Gateway__RequireAuthentication": "true",
        "ReverseProxy__Clusters__identity__Destinations__d1__Address": "http://identity-bff-service:5275/",
        "ReverseProxy__Clusters__his-bff__Destinations__d1__Address": "http://his-bff-service:5301/",
        "ReverseProxy__Clusters__ehr-bff__Destinations__d1__Address": "http://ehr-bff-service:5302/",
        "ReverseProxy__Clusters__pdms-bff__Destinations__d1__Address": "http://pdms-bff-service:5303/",
        "ReverseProxy__Clusters__smartconnect-bff__Destinations__d1__Address": "http://smartconnect-bff-service:5304/",
        "ReverseProxy__Clusters__hie-bff__Destinations__d1__Address": "http://hie-bff-service:5305/",
        "ReverseProxy__Clusters__admin-bff__Destinations__d1__Address": "http://admin-bff-service:5306/",
        "ReverseProxy__Clusters__portal-bff__Destinations__d1__Address": "http://portal-bff-service:5307/",
        "ReverseProxy__Clusters__his-web__Destinations__d1__Address": "http://his-web-service:5331/",
        "ReverseProxy__Clusters__ehr-web__Destinations__d1__Address": "http://ehr-web-service:5332/",
        "ReverseProxy__Clusters__pdms-web__Destinations__d1__Address": "http://pdms-web-service:5333/",
        "ReverseProxy__Clusters__smartconnect-web__Destinations__d1__Address": "http://smartconnect-web-service:5334/",
        "ReverseProxy__Clusters__hie-web__Destinations__d1__Address": "http://hie-web-service:5335/",
        "ReverseProxy__Clusters__admin-web__Destinations__d1__Address": "http://identity-web-service:5336/",
        "ReverseProxy__Clusters__portal-web__Destinations__d1__Address": "http://patient-portal-web-service:5337/",
        "ReverseProxy__Clusters__keycloak__Destinations__d1__Address": "http://keycloak-service:8081/"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 9090,
          "external": true
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http",
          "external": true
        }
      }
    },
    "rabbitmq-password": {
      "type": "parameter.v0",
      "value": "{rabbitmq-password.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true,
          "default": {
            "generate": {
              "minLength": 22,
              "special": false
            }
          }
        }
      }
    },
    "rabbitmq-password-uri-encoded": {
      "type": "annotated.string",
      "value": "{rabbitmq-password.value}",
      "filter": "uri"
    },
    "valkey-password": {
      "type": "parameter.v0",
      "value": "{valkey-password.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true,
          "default": {
            "generate": {
              "minLength": 22,
              "special": false
            }
          }
        }
      }
    }
  }
}