{
  "resources": {
    "unit-registry": {
      "error": "This resource does not support generation in the manifest."
    },
    "k8s": {
      "error": "This resource does not support generation in the manifest."
    },
    "rabbitmq-connection": {
      "type": "parameter.v0",
      "value": "{rabbitmq-connection.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "amqp://guest:CHANGE-ME@rabbitmq-service:5672"
          }
        }
      }
    },
    "valkey-connection": {
      "type": "parameter.v0",
      "value": "{valkey-connection.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "valkey-service:6379,password=CHANGE-ME"
          }
        }
      }
    },
    "rabbitmq": {
      "type": "value.v0",
      "connectionString": "{rabbitmq-connection.value}"
    },
    "valkey": {
      "type": "value.v0",
      "connectionString": "{valkey-connection.value}"
    },
    "keycloak-authority": {
      "type": "parameter.v0",
      "value": "{keycloak-authority.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "http://keycloak-service:8081/realms/dialysis"
          }
        }
      }
    },
    "ehr-bff-client-secret": {
      "type": "parameter.v0",
      "value": "{ehr-bff-client-secret.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true
        }
      }
    },
    "postgres-ehr": {
      "type": "container.v1",
      "connectionString": "Host={postgres-ehr.bindings.tcp.host};Port={postgres-ehr.bindings.tcp.port};Username=postgres;Password={postgres-ehr-password.value}",
      "image": "docker.io/postgres:17-alpine",
      "volumes": [
        {
          "name": "dialysis-postgres-ehr-data",
          "target": "/var/lib/postgresql/data",
          "readOnly": false
        }
      ],
      "env": {
        "POSTGRES_HOST_AUTH_METHOD": "scram-sha-256",
        "POSTGRES_INITDB_ARGS": "--auth-host=scram-sha-256 --auth-local=scram-sha-256",
        "POSTGRES_USER": "postgres",
        "POSTGRES_PASSWORD": "{postgres-ehr-password.value}"
      },
      "bindings": {
        "tcp": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "targetPort": 5432
        }
      }
    },
    "Ehr": {
      "type": "value.v0",
      "connectionString": "{postgres-ehr.connectionString};Database=dialysis_ehr"
    },
    "ehr-api": {
      "type": "project.v1",
      "path": "../../../../../src/backend/EHR/Dialysis.EHR.Api/Dialysis.EHR.Api.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{ehr-api.bindings.http.targetPort}",
        "ConnectionStrings__Ehr": "{Ehr.connectionString}",
        "EHR_HOST": "{postgres-ehr.bindings.tcp.host}",
        "EHR_PORT": "{postgres-ehr.bindings.tcp.port}",
        "EHR_USERNAME": "postgres",
        "EHR_PASSWORD": "{postgres-ehr-password.value}",
        "EHR_URI": "postgresql://postgres:{postgres-ehr-password-uri-encoded.value}@{postgres-ehr.bindings.tcp.host}:{postgres-ehr.bindings.tcp.port}/dialysis_ehr",
        "EHR_JDBCCONNECTIONSTRING": "jdbc:postgresql://{postgres-ehr.bindings.tcp.host}:{postgres-ehr.bindings.tcp.port}/dialysis_ehr",
        "EHR_DATABASENAME": "dialysis_ehr",
        "ConnectionStrings__Hangfire": "{Ehr.connectionString}",
        "HANGFIRE_HOST": "{postgres-ehr.bindings.tcp.host}",
        "HANGFIRE_PORT": "{postgres-ehr.bindings.tcp.port}",
        "HANGFIRE_USERNAME": "postgres",
        "HANGFIRE_PASSWORD": "{postgres-ehr-password.value}",
        "HANGFIRE_URI": "postgresql://postgres:{postgres-ehr-password-uri-encoded.value}@{postgres-ehr.bindings.tcp.host}:{postgres-ehr.bindings.tcp.port}/dialysis_ehr",
        "HANGFIRE_JDBCCONNECTIONSTRING": "jdbc:postgresql://{postgres-ehr.bindings.tcp.host}:{postgres-ehr.bindings.tcp.port}/dialysis_ehr",
        "HANGFIRE_DATABASENAME": "dialysis_ehr",
        "ConnectionStrings__rabbitmq": "{rabbitmq.connectionString}",
        "ConnectionStrings__valkey": "{valkey.connectionString}",
        "Ehr__Transponder__EnableOutboxRelay": "true",
        "Ehr__Transponder__RabbitMq__ConnectionUri": "{rabbitmq.connectionString}",
        "Ehr__DistributedCache__Valkey__ConnectionString": "{valkey.connectionString}",
        "Ehr__Authentication__Authority": "{keycloak-authority.value}",
        "Ehr__Authentication__Audience": "account"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "ehr-bff": {
      "type": "project.v1",
      "path": "../../../../../src/backend/EHR/Dialysis.EHR.Bff/Dialysis.EHR.Bff.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "ASPNETCORE_URLS": "http://\u002B:5302",
        "Bff__Keycloak__Authority": "{keycloak-authority.value}",
        "Bff__Keycloak__ClientSecret": "{ehr-bff-client-secret.value}",
        "Bff__Module__ModuleApiAddress": "{ehr-api.bindings.http.url}",
        "ConnectionStrings__rabbitmq": "{rabbitmq.connectionString}",
        "ConnectionStrings__valkey": "{valkey.connectionString}",
        "Bff__Events__RabbitMq__ConnectionUri": "{rabbitmq.connectionString}",
        "Bff__Events__SignalR__BackplaneConnectionString": "{valkey.connectionString}",
        "ConnectionStrings__Hangfire": "{Ehr.connectionString}",
        "HANGFIRE_HOST": "{postgres-ehr.bindings.tcp.host}",
        "HANGFIRE_PORT": "{postgres-ehr.bindings.tcp.port}",
        "HANGFIRE_USERNAME": "postgres",
        "HANGFIRE_PASSWORD": "{postgres-ehr-password.value}",
        "HANGFIRE_URI": "postgresql://postgres:{postgres-ehr-password-uri-encoded.value}@{postgres-ehr.bindings.tcp.host}:{postgres-ehr.bindings.tcp.port}/dialysis_ehr",
        "HANGFIRE_JDBCCONNECTIONSTRING": "jdbc:postgresql://{postgres-ehr.bindings.tcp.host}:{postgres-ehr.bindings.tcp.port}/dialysis_ehr",
        "HANGFIRE_DATABASENAME": "dialysis_ehr",
        "Bff__Module__Aggregations__0__Address": "http://hie-api-service:8080",
        "Bff__Module__Aggregations__1__Address": "http://lab-api-service:8080",
        "Bff__Module__Aggregations__2__Address": "http://smartconnect-api-service:8080"
      },
      "bindings": {
        "http": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "targetPort": 5302
        }
      }
    },
    "ehr-web": {
      "type": "container.v1",
      "build": {
        "context": "../../../../../src/frontend/ehr-web",
        "dockerfile": "../../../../../src/frontend/ehr-web/Dockerfile"
      },
      "env": {
        "NODE_ENV": "production",
        "BROWSER": "none",
        "VITE_GATEWAY_URL": "http://gateway-service:9090",
        "VITE_API_BASE_URL": "http://gateway-service:9090",
        "PORT": "{ehr-web.bindings.http.targetPort}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 5332
        }
      }
    },
    "postgres-ehr-password": {
      "type": "parameter.v0",
      "value": "{postgres-ehr-password.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true,
          "default": {
            "generate": {
              "minLength": 22
            }
          }
        }
      }
    },
    "postgres-ehr-password-uri-encoded": {
      "type": "annotated.string",
      "value": "{postgres-ehr-password.value}",
      "filter": "uri"
    }
  }
}