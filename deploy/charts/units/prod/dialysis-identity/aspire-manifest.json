{
  "resources": {
    "unit-registry": {
      "error": "This resource does not support generation in the manifest."
    },
    "k8s": {
      "error": "This resource does not support generation in the manifest."
    },
    "rabbitmq-connection": {
      "type": "parameter.v0",
      "value": "{rabbitmq-connection.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "amqp://guest:CHANGE-ME@rabbitmq-service:5672"
          }
        }
      }
    },
    "valkey-connection": {
      "type": "parameter.v0",
      "value": "{valkey-connection.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "valkey-service:6379,password=CHANGE-ME"
          }
        }
      }
    },
    "rabbitmq": {
      "type": "value.v0",
      "connectionString": "{rabbitmq-connection.value}"
    },
    "valkey": {
      "type": "value.v0",
      "connectionString": "{valkey-connection.value}"
    },
    "keycloak": {
      "type": "container.v1",
      "image": "quay.io/keycloak/keycloak:26.0",
      "args": [
        "start-dev",
        "--import-realm"
      ],
      "env": {
        "KC_BOOTSTRAP_ADMIN_USERNAME": "admin",
        "KC_BOOTSTRAP_ADMIN_PASSWORD": "admin",
        "KC_DB": "dev-mem",
        "KC_HEALTH_ENABLED": "true",
        "KC_HTTP_ENABLED": "true"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "port": 8081,
          "targetPort": 8080
        }
      }
    },
    "admin-bff-client-secret": {
      "type": "parameter.v0",
      "value": "{admin-bff-client-secret.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true
        }
      }
    },
    "identity-bff-client-secret": {
      "type": "parameter.v0",
      "value": "{identity-bff-client-secret.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true
        }
      }
    },
    "hangfire-his-connection": {
      "type": "parameter.v0",
      "value": "{hangfire-his-connection.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "Host=postgres-his-service;Port=5432;Username=postgres;Password=CHANGE-ME;Database=dialysis_his"
          }
        }
      }
    },
    "hangfire-his": {
      "type": "value.v0",
      "connectionString": "{hangfire-his-connection.value}"
    },
    "hangfire-hie-connection": {
      "type": "parameter.v0",
      "value": "{hangfire-hie-connection.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "Host=postgres-hie-service;Port=5432;Username=postgres;Password=CHANGE-ME;Database=dialysis_hie"
          }
        }
      }
    },
    "hangfire-hie": {
      "type": "value.v0",
      "connectionString": "{hangfire-hie-connection.value}"
    },
    "identity-bff": {
      "type": "project.v1",
      "path": "../../../../../src/backend/Identity/Dialysis.Identity.Bff/Dialysis.Identity.Bff.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{identity-bff.bindings.http.targetPort}",
        "ConnectionStrings__Hangfire": "{hangfire-his.connectionString}",
        "ASPNETCORE_URLS": "http://\u002B:5275",
        "Identity__Keycloak__Authority": "{keycloak.bindings.http.url}/realms/dialysis",
        "Identity__Keycloak__ClientSecret": "{identity-bff-client-secret.value}",
        "ReverseProxy__Clusters__his__Destinations__d1__Address": "http://his-api-service:8080/"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 5275
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "admin-bff": {
      "type": "project.v1",
      "path": "../../../../../src/backend/Identity/Dialysis.Admin.Bff/Dialysis.Admin.Bff.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "ASPNETCORE_URLS": "http://\u002B:5306",
        "Bff__Keycloak__Authority": "{keycloak.bindings.http.url}/realms/dialysis",
        "Bff__Keycloak__ClientSecret": "{admin-bff-client-secret.value}",
        "Bff__Module__ModuleApiAddress": "http://hie-api-service:8080",
        "ConnectionStrings__rabbitmq": "{rabbitmq.connectionString}",
        "ConnectionStrings__valkey": "{valkey.connectionString}",
        "Bff__Events__RabbitMq__ConnectionUri": "{rabbitmq.connectionString}",
        "Bff__Events__SignalR__BackplaneConnectionString": "{valkey.connectionString}",
        "ConnectionStrings__Hangfire": "{hangfire-hie.connectionString}",
        "Bff__Module__Aggregations__0__Address": "http://his-api-service:8080",
        "Bff__Module__Aggregations__1__Address": "http://ehr-api-service:8080",
        "Bff__Module__Aggregations__2__Address": "http://pdms-api-service:8080",
        "Bff__Module__Aggregations__3__Address": "http://smartconnect-api-service:8080"
      },
      "bindings": {
        "http": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "targetPort": 5306
        }
      }
    },
    "identity-web": {
      "type": "container.v1",
      "build": {
        "context": "../../../../../src/frontend/identity-web",
        "dockerfile": "../../../../../src/frontend/identity-web/Dockerfile"
      },
      "env": {
        "NODE_ENV": "production",
        "BROWSER": "none",
        "VITE_GATEWAY_URL": "http://gateway-service:9090",
        "VITE_API_BASE_URL": "http://gateway-service:9090",
        "PORT": "{identity-web.bindings.http.targetPort}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 5336
        }
      }
    }
  }
}