{
  "resources": {
    "unit-registry": {
      "error": "This resource does not support generation in the manifest."
    },
    "k8s": {
      "error": "This resource does not support generation in the manifest."
    },
    "rabbitmq-connection": {
      "type": "parameter.v0",
      "value": "{rabbitmq-connection.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "amqp://guest:CHANGE-ME@rabbitmq-service:5672"
          }
        }
      }
    },
    "valkey-connection": {
      "type": "parameter.v0",
      "value": "{valkey-connection.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "valkey-service:6379,password=CHANGE-ME"
          }
        }
      }
    },
    "rabbitmq": {
      "type": "value.v0",
      "connectionString": "{rabbitmq-connection.value}"
    },
    "valkey": {
      "type": "value.v0",
      "connectionString": "{valkey-connection.value}"
    },
    "keycloak-authority": {
      "type": "parameter.v0",
      "value": "{keycloak-authority.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "http://keycloak-service:8081/realms/dialysis"
          }
        }
      }
    },
    "portal-bff-client-secret": {
      "type": "parameter.v0",
      "value": "{portal-bff-client-secret.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true
        }
      }
    },
    "hangfire-his-connection": {
      "type": "parameter.v0",
      "value": "{hangfire-his-connection.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "Host=postgres-his-service;Port=5432;Username=postgres;Password=CHANGE-ME;Database=dialysis_his"
          }
        }
      }
    },
    "hangfire-his": {
      "type": "value.v0",
      "connectionString": "{hangfire-his-connection.value}"
    },
    "portal-bff": {
      "type": "project.v1",
      "path": "../../../../../src/backend/PatientPortal/Dialysis.PatientPortal.Bff/Dialysis.PatientPortal.Bff.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "ASPNETCORE_URLS": "http://\u002B:5307",
        "Bff__Keycloak__Authority": "{keycloak-authority.value}",
        "Bff__Keycloak__ClientSecret": "{portal-bff-client-secret.value}",
        "Bff__Module__ModuleApiAddress": "http://his-api-service:8080",
        "ConnectionStrings__rabbitmq": "{rabbitmq.connectionString}",
        "ConnectionStrings__valkey": "{valkey.connectionString}",
        "Bff__Events__RabbitMq__ConnectionUri": "{rabbitmq.connectionString}",
        "Bff__Events__SignalR__BackplaneConnectionString": "{valkey.connectionString}",
        "ConnectionStrings__Hangfire": "{hangfire-his.connectionString}",
        "Bff__Module__Aggregations__0__Address": "http://ehr-api-service:8080",
        "Bff__Module__Aggregations__1__Address": "http://pdms-api-service:8080",
        "Bff__Module__Aggregations__2__Address": "http://hie-api-service:8080",
        "Bff__Module__Aggregations__3__Address": "http://smartconnect-api-service:8080"
      },
      "bindings": {
        "http": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "targetPort": 5307
        }
      }
    },
    "patient-portal-web": {
      "type": "container.v1",
      "build": {
        "context": "../../../../../src/frontend/patient-portal-web",
        "dockerfile": "../../../../../src/frontend/patient-portal-web/Dockerfile"
      },
      "env": {
        "NODE_ENV": "production",
        "BROWSER": "none",
        "VITE_GATEWAY_URL": "http://gateway-service:9090",
        "VITE_API_BASE_URL": "http://gateway-service:9090",
        "PORT": "{patient-portal-web.bindings.http.targetPort}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 5337
        }
      }
    }
  }
}