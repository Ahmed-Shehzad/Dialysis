{
  "resources": {
    "unit-registry": {
      "error": "This resource does not support generation in the manifest."
    },
    "k8s": {
      "error": "This resource does not support generation in the manifest."
    },
    "rabbitmq-connection": {
      "type": "parameter.v0",
      "value": "{rabbitmq-connection.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "amqp://guest:CHANGE-ME@rabbitmq-service:5672"
          }
        }
      }
    },
    "valkey-connection": {
      "type": "parameter.v0",
      "value": "{valkey-connection.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "valkey-service:6379,password=CHANGE-ME"
          }
        }
      }
    },
    "rabbitmq": {
      "type": "value.v0",
      "connectionString": "{rabbitmq-connection.value}"
    },
    "valkey": {
      "type": "value.v0",
      "connectionString": "{valkey-connection.value}"
    },
    "keycloak-authority": {
      "type": "parameter.v0",
      "value": "{keycloak-authority.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "http://keycloak-service:8081/realms/dialysis"
          }
        }
      }
    },
    "his-bff-client-secret": {
      "type": "parameter.v0",
      "value": "{his-bff-client-secret.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true
        }
      }
    },
    "postgres-his": {
      "type": "container.v1",
      "connectionString": "Host={postgres-his.bindings.tcp.host};Port={postgres-his.bindings.tcp.port};Username=postgres;Password={postgres-his-password.value}",
      "image": "docker.io/postgres:17-alpine",
      "volumes": [
        {
          "name": "dialysis-postgres-his-data",
          "target": "/var/lib/postgresql/data",
          "readOnly": false
        }
      ],
      "env": {
        "POSTGRES_HOST_AUTH_METHOD": "scram-sha-256",
        "POSTGRES_INITDB_ARGS": "--auth-host=scram-sha-256 --auth-local=scram-sha-256",
        "POSTGRES_USER": "postgres",
        "POSTGRES_PASSWORD": "{postgres-his-password.value}"
      },
      "bindings": {
        "tcp": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "targetPort": 5432
        }
      }
    },
    "His": {
      "type": "value.v0",
      "connectionString": "{postgres-his.connectionString};Database=dialysis_his"
    },
    "his-api": {
      "type": "project.v1",
      "path": "../../../../../src/backend/HIS/Dialysis.HIS.Api/Dialysis.HIS.Api.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{his-api.bindings.http.targetPort}",
        "ConnectionStrings__His": "{His.connectionString}",
        "HIS_HOST": "{postgres-his.bindings.tcp.host}",
        "HIS_PORT": "{postgres-his.bindings.tcp.port}",
        "HIS_USERNAME": "postgres",
        "HIS_PASSWORD": "{postgres-his-password.value}",
        "HIS_URI": "postgresql://postgres:{postgres-his-password-uri-encoded.value}@{postgres-his.bindings.tcp.host}:{postgres-his.bindings.tcp.port}/dialysis_his",
        "HIS_JDBCCONNECTIONSTRING": "jdbc:postgresql://{postgres-his.bindings.tcp.host}:{postgres-his.bindings.tcp.port}/dialysis_his",
        "HIS_DATABASENAME": "dialysis_his",
        "ConnectionStrings__Hangfire": "{His.connectionString}",
        "HANGFIRE_HOST": "{postgres-his.bindings.tcp.host}",
        "HANGFIRE_PORT": "{postgres-his.bindings.tcp.port}",
        "HANGFIRE_USERNAME": "postgres",
        "HANGFIRE_PASSWORD": "{postgres-his-password.value}",
        "HANGFIRE_URI": "postgresql://postgres:{postgres-his-password-uri-encoded.value}@{postgres-his.bindings.tcp.host}:{postgres-his.bindings.tcp.port}/dialysis_his",
        "HANGFIRE_JDBCCONNECTIONSTRING": "jdbc:postgresql://{postgres-his.bindings.tcp.host}:{postgres-his.bindings.tcp.port}/dialysis_his",
        "HANGFIRE_DATABASENAME": "dialysis_his",
        "ConnectionStrings__rabbitmq": "{rabbitmq.connectionString}",
        "ConnectionStrings__valkey": "{valkey.connectionString}",
        "His__Transponder__EnableOutboxRelay": "true",
        "His__Transponder__RabbitMq__ConnectionUri": "{rabbitmq.connectionString}",
        "His__DistributedCache__Valkey__ConnectionString": "{valkey.connectionString}",
        "His__Authentication__Authority": "{keycloak-authority.value}",
        "His__Authentication__Audience": "account",
        "His__Fhir__Enabled": "true"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "his-bff": {
      "type": "project.v1",
      "path": "../../../../../src/backend/HIS/Dialysis.HIS.Bff/Dialysis.HIS.Bff.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "ASPNETCORE_URLS": "http://\u002B:5301",
        "Bff__Keycloak__Authority": "{keycloak-authority.value}",
        "Bff__Keycloak__ClientSecret": "{his-bff-client-secret.value}",
        "Bff__Module__ModuleApiAddress": "{his-api.bindings.http.url}",
        "ConnectionStrings__rabbitmq": "{rabbitmq.connectionString}",
        "ConnectionStrings__valkey": "{valkey.connectionString}",
        "Bff__Events__RabbitMq__ConnectionUri": "{rabbitmq.connectionString}",
        "Bff__Events__SignalR__BackplaneConnectionString": "{valkey.connectionString}",
        "ConnectionStrings__Hangfire": "{His.connectionString}",
        "HANGFIRE_HOST": "{postgres-his.bindings.tcp.host}",
        "HANGFIRE_PORT": "{postgres-his.bindings.tcp.port}",
        "HANGFIRE_USERNAME": "postgres",
        "HANGFIRE_PASSWORD": "{postgres-his-password.value}",
        "HANGFIRE_URI": "postgresql://postgres:{postgres-his-password-uri-encoded.value}@{postgres-his.bindings.tcp.host}:{postgres-his.bindings.tcp.port}/dialysis_his",
        "HANGFIRE_JDBCCONNECTIONSTRING": "jdbc:postgresql://{postgres-his.bindings.tcp.host}:{postgres-his.bindings.tcp.port}/dialysis_his",
        "HANGFIRE_DATABASENAME": "dialysis_his",
        "Bff__Module__Aggregations__0__Address": "http://smartconnect-api-service:8080"
      },
      "bindings": {
        "http": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "targetPort": 5301
        }
      }
    },
    "his-web": {
      "type": "container.v1",
      "build": {
        "context": "../../../../../src/frontend/his-web",
        "dockerfile": "../../../../../src/frontend/his-web/Dockerfile"
      },
      "env": {
        "NODE_ENV": "production",
        "BROWSER": "none",
        "VITE_GATEWAY_URL": "http://gateway-service:9090",
        "VITE_API_BASE_URL": "http://gateway-service:9090",
        "PORT": "{his-web.bindings.http.targetPort}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 5331
        }
      }
    },
    "postgres-his-password": {
      "type": "parameter.v0",
      "value": "{postgres-his-password.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true,
          "default": {
            "generate": {
              "minLength": 22
            }
          }
        }
      }
    },
    "postgres-his-password-uri-encoded": {
      "type": "annotated.string",
      "value": "{postgres-his-password.value}",
      "filter": "uri"
    }
  }
}