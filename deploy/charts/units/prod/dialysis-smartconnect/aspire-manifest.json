{
  "resources": {
    "unit-registry": {
      "error": "This resource does not support generation in the manifest."
    },
    "k8s": {
      "error": "This resource does not support generation in the manifest."
    },
    "rabbitmq-connection": {
      "type": "parameter.v0",
      "value": "{rabbitmq-connection.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "amqp://guest:CHANGE-ME@rabbitmq-service:5672"
          }
        }
      }
    },
    "valkey-connection": {
      "type": "parameter.v0",
      "value": "{valkey-connection.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "valkey-service:6379,password=CHANGE-ME"
          }
        }
      }
    },
    "rabbitmq": {
      "type": "value.v0",
      "connectionString": "{rabbitmq-connection.value}"
    },
    "valkey": {
      "type": "value.v0",
      "connectionString": "{valkey-connection.value}"
    },
    "keycloak-authority": {
      "type": "parameter.v0",
      "value": "{keycloak-authority.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "http://keycloak-service:8081/realms/dialysis"
          }
        }
      }
    },
    "smartconnect-bff-client-secret": {
      "type": "parameter.v0",
      "value": "{smartconnect-bff-client-secret.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true
        }
      }
    },
    "postgres-smartconnect": {
      "type": "container.v1",
      "connectionString": "Host={postgres-smartconnect.bindings.tcp.host};Port={postgres-smartconnect.bindings.tcp.port};Username=postgres;Password={postgres-smartconnect-password.value}",
      "image": "docker.io/postgres:17-alpine",
      "volumes": [
        {
          "name": "dialysis-postgres-smartconnect-data",
          "target": "/var/lib/postgresql/data",
          "readOnly": false
        }
      ],
      "env": {
        "POSTGRES_HOST_AUTH_METHOD": "scram-sha-256",
        "POSTGRES_INITDB_ARGS": "--auth-host=scram-sha-256 --auth-local=scram-sha-256",
        "POSTGRES_USER": "postgres",
        "POSTGRES_PASSWORD": "{postgres-smartconnect-password.value}"
      },
      "bindings": {
        "tcp": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "targetPort": 5432
        }
      }
    },
    "SmartConnect": {
      "type": "value.v0",
      "connectionString": "{postgres-smartconnect.connectionString};Database=dialysis_smartconnect"
    },
    "smartconnect-api": {
      "type": "project.v1",
      "path": "../../../../../src/backend/SmartConnect/Api/Dialysis.SmartConnect.Api/Dialysis.SmartConnect.Api.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{smartconnect-api.bindings.http.targetPort}",
        "ConnectionStrings__SmartConnect": "{SmartConnect.connectionString}",
        "SMARTCONNECT_HOST": "{postgres-smartconnect.bindings.tcp.host}",
        "SMARTCONNECT_PORT": "{postgres-smartconnect.bindings.tcp.port}",
        "SMARTCONNECT_USERNAME": "postgres",
        "SMARTCONNECT_PASSWORD": "{postgres-smartconnect-password.value}",
        "SMARTCONNECT_URI": "postgresql://postgres:{postgres-smartconnect-password-uri-encoded.value}@{postgres-smartconnect.bindings.tcp.host}:{postgres-smartconnect.bindings.tcp.port}/dialysis_smartconnect",
        "SMARTCONNECT_JDBCCONNECTIONSTRING": "jdbc:postgresql://{postgres-smartconnect.bindings.tcp.host}:{postgres-smartconnect.bindings.tcp.port}/dialysis_smartconnect",
        "SMARTCONNECT_DATABASENAME": "dialysis_smartconnect",
        "ConnectionStrings__Hangfire": "{SmartConnect.connectionString}",
        "HANGFIRE_HOST": "{postgres-smartconnect.bindings.tcp.host}",
        "HANGFIRE_PORT": "{postgres-smartconnect.bindings.tcp.port}",
        "HANGFIRE_USERNAME": "postgres",
        "HANGFIRE_PASSWORD": "{postgres-smartconnect-password.value}",
        "HANGFIRE_URI": "postgresql://postgres:{postgres-smartconnect-password-uri-encoded.value}@{postgres-smartconnect.bindings.tcp.host}:{postgres-smartconnect.bindings.tcp.port}/dialysis_smartconnect",
        "HANGFIRE_JDBCCONNECTIONSTRING": "jdbc:postgresql://{postgres-smartconnect.bindings.tcp.host}:{postgres-smartconnect.bindings.tcp.port}/dialysis_smartconnect",
        "HANGFIRE_DATABASENAME": "dialysis_smartconnect",
        "ConnectionStrings__rabbitmq": "{rabbitmq.connectionString}",
        "ConnectionStrings__valkey": "{valkey.connectionString}",
        "SmartConnect__Transponder__EnableOutboxRelay": "true",
        "SmartConnect__Transponder__RabbitMq__ConnectionUri": "{rabbitmq.connectionString}",
        "SmartConnect__DistributedCache__Valkey__ConnectionString": "{valkey.connectionString}",
        "SmartConnect__Authentication__Authority": "{keycloak-authority.value}",
        "SmartConnect__Authentication__Audience": "account",
        "SmartConnect__SourceConnectors__0__Name": "Hl7Mllp",
        "SmartConnect__SourceConnectors__0__Kind": "mllp",
        "SmartConnect__SourceConnectors__0__DefaultFlowId": "b1d10001-0001-4000-8000-000000000001",
        "SmartConnect__SourceConnectors__0__Parameters__Port": "2575",
        "SmartConnect__SourceConnectors__1__Name": "LocalDrop",
        "SmartConnect__SourceConnectors__1__Kind": "file-reader",
        "SmartConnect__SourceConnectors__1__DefaultFlowId": "b1d10001-0001-4000-8000-000000000001",
        "SmartConnect__SourceConnectors__1__Parameters__Directory": "./tmp/smartconnect/drop",
        "SmartConnect__SourceConnectors__1__Parameters__Pattern": "*.hl7"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "smartconnect-bff": {
      "type": "project.v1",
      "path": "../../../../../src/backend/SmartConnect/Dialysis.SmartConnect.Bff/Dialysis.SmartConnect.Bff.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "ASPNETCORE_URLS": "http://\u002B:5304",
        "Bff__Keycloak__Authority": "{keycloak-authority.value}",
        "Bff__Keycloak__ClientSecret": "{smartconnect-bff-client-secret.value}",
        "Bff__Module__ModuleApiAddress": "{smartconnect-api.bindings.http.url}",
        "ConnectionStrings__rabbitmq": "{rabbitmq.connectionString}",
        "ConnectionStrings__valkey": "{valkey.connectionString}",
        "Bff__Events__RabbitMq__ConnectionUri": "{rabbitmq.connectionString}",
        "Bff__Events__SignalR__BackplaneConnectionString": "{valkey.connectionString}",
        "ConnectionStrings__Hangfire": "{SmartConnect.connectionString}",
        "HANGFIRE_HOST": "{postgres-smartconnect.bindings.tcp.host}",
        "HANGFIRE_PORT": "{postgres-smartconnect.bindings.tcp.port}",
        "HANGFIRE_USERNAME": "postgres",
        "HANGFIRE_PASSWORD": "{postgres-smartconnect-password.value}",
        "HANGFIRE_URI": "postgresql://postgres:{postgres-smartconnect-password-uri-encoded.value}@{postgres-smartconnect.bindings.tcp.host}:{postgres-smartconnect.bindings.tcp.port}/dialysis_smartconnect",
        "HANGFIRE_JDBCCONNECTIONSTRING": "jdbc:postgresql://{postgres-smartconnect.bindings.tcp.host}:{postgres-smartconnect.bindings.tcp.port}/dialysis_smartconnect",
        "HANGFIRE_DATABASENAME": "dialysis_smartconnect"
      },
      "bindings": {
        "http": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "targetPort": 5304
        }
      }
    },
    "smartconnect-web": {
      "type": "container.v1",
      "build": {
        "context": "../../../../../src/frontend/smartconnect-web",
        "dockerfile": "../../../../../src/frontend/smartconnect-web/Dockerfile"
      },
      "env": {
        "NODE_ENV": "production",
        "BROWSER": "none",
        "VITE_GATEWAY_URL": "http://gateway-service:9090",
        "VITE_API_BASE_URL": "http://gateway-service:9090",
        "PORT": "{smartconnect-web.bindings.http.targetPort}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 5334
        }
      }
    },
    "postgres-smartconnect-password": {
      "type": "parameter.v0",
      "value": "{postgres-smartconnect-password.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true,
          "default": {
            "generate": {
              "minLength": 22
            }
          }
        }
      }
    },
    "postgres-smartconnect-password-uri-encoded": {
      "type": "annotated.string",
      "value": "{postgres-smartconnect-password.value}",
      "filter": "uri"
    }
  }
}