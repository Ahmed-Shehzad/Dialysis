{
  "resources": {
    "unit-registry": {
      "error": "This resource does not support generation in the manifest."
    },
    "k8s": {
      "error": "This resource does not support generation in the manifest."
    },
    "rabbitmq-connection": {
      "type": "parameter.v0",
      "value": "{rabbitmq-connection.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "amqp://guest:CHANGE-ME@rabbitmq-service:5672"
          }
        }
      }
    },
    "valkey-connection": {
      "type": "parameter.v0",
      "value": "{valkey-connection.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "valkey-service:6379,password=CHANGE-ME"
          }
        }
      }
    },
    "rabbitmq": {
      "type": "value.v0",
      "connectionString": "{rabbitmq-connection.value}"
    },
    "valkey": {
      "type": "value.v0",
      "connectionString": "{valkey-connection.value}"
    },
    "keycloak-authority": {
      "type": "parameter.v0",
      "value": "{keycloak-authority.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "default": {
            "value": "http://keycloak-service:8081/realms/dialysis"
          }
        }
      }
    },
    "postgres-lab": {
      "type": "container.v1",
      "connectionString": "Host={postgres-lab.bindings.tcp.host};Port={postgres-lab.bindings.tcp.port};Username=postgres;Password={postgres-lab-password.value}",
      "image": "docker.io/postgres:17-alpine",
      "volumes": [
        {
          "name": "dialysis-postgres-lab-data",
          "target": "/var/lib/postgresql/data",
          "readOnly": false
        }
      ],
      "env": {
        "POSTGRES_HOST_AUTH_METHOD": "scram-sha-256",
        "POSTGRES_INITDB_ARGS": "--auth-host=scram-sha-256 --auth-local=scram-sha-256",
        "POSTGRES_USER": "postgres",
        "POSTGRES_PASSWORD": "{postgres-lab-password.value}"
      },
      "bindings": {
        "tcp": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "targetPort": 5432
        }
      }
    },
    "Lab": {
      "type": "value.v0",
      "connectionString": "{postgres-lab.connectionString};Database=dialysis_lab"
    },
    "lab-api": {
      "type": "project.v1",
      "path": "../../../../../src/backend/Lab/Dialysis.Lab.Api/Dialysis.Lab.Api.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{lab-api.bindings.http.targetPort}",
        "ConnectionStrings__Lab": "{Lab.connectionString}",
        "LAB_HOST": "{postgres-lab.bindings.tcp.host}",
        "LAB_PORT": "{postgres-lab.bindings.tcp.port}",
        "LAB_USERNAME": "postgres",
        "LAB_PASSWORD": "{postgres-lab-password.value}",
        "LAB_URI": "postgresql://postgres:{postgres-lab-password-uri-encoded.value}@{postgres-lab.bindings.tcp.host}:{postgres-lab.bindings.tcp.port}/dialysis_lab",
        "LAB_JDBCCONNECTIONSTRING": "jdbc:postgresql://{postgres-lab.bindings.tcp.host}:{postgres-lab.bindings.tcp.port}/dialysis_lab",
        "LAB_DATABASENAME": "dialysis_lab",
        "ConnectionStrings__Hangfire": "{Lab.connectionString}",
        "HANGFIRE_HOST": "{postgres-lab.bindings.tcp.host}",
        "HANGFIRE_PORT": "{postgres-lab.bindings.tcp.port}",
        "HANGFIRE_USERNAME": "postgres",
        "HANGFIRE_PASSWORD": "{postgres-lab-password.value}",
        "HANGFIRE_URI": "postgresql://postgres:{postgres-lab-password-uri-encoded.value}@{postgres-lab.bindings.tcp.host}:{postgres-lab.bindings.tcp.port}/dialysis_lab",
        "HANGFIRE_JDBCCONNECTIONSTRING": "jdbc:postgresql://{postgres-lab.bindings.tcp.host}:{postgres-lab.bindings.tcp.port}/dialysis_lab",
        "HANGFIRE_DATABASENAME": "dialysis_lab",
        "ConnectionStrings__rabbitmq": "{rabbitmq.connectionString}",
        "ConnectionStrings__valkey": "{valkey.connectionString}",
        "Lab__Transponder__EnableOutboxRelay": "true",
        "Lab__Transponder__RabbitMq__ConnectionUri": "{rabbitmq.connectionString}",
        "Lab__DistributedCache__Valkey__ConnectionString": "{valkey.connectionString}",
        "Lab__Authentication__Authority": "{keycloak-authority.value}",
        "Lab__Authentication__Audience": "account"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "postgres-lab-password": {
      "type": "parameter.v0",
      "value": "{postgres-lab-password.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true,
          "default": {
            "generate": {
              "minLength": 22
            }
          }
        }
      }
    },
    "postgres-lab-password-uri-encoded": {
      "type": "annotated.string",
      "value": "{postgres-lab-password.value}",
      "filter": "uri"
    }
  }
}