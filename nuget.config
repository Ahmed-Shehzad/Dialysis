<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Clear any machine-/user-level sources so restores are reproducible across dev
         machines and CI, then pin to nuget.org (the only feed this repo uses today). -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <!-- Supply-chain hardening: every package id resolves from nuget.org only. If a private
         feed is added later, give it its own <packageSource> block with explicit patterns. -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
